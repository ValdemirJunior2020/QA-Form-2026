# .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Google service account / private keys
service-account.json
*.pem
*.key
*.p12
*.json.key

# Build output
dist/
build/
out/

# Vite / React cache
.vite/
node_modules/.vite/

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/

# Netlify / Vercel
.netlify/
.vercel/

# Render / deployment local files
.render/

# Optional package manager files
.pnpm-store/
.yarn/
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
# Google service account keys
*.json
*service-account*.json
*firebase-adminsdk*.json
*psych-support-app*.json

# Env files
.env
.env.local
.env.production
.env.development

# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Builds
dist/
build/
client/dist/
client/build/
server/dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/